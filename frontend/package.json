		"@sveltejs/vite-plugin-svelte": "^5.1.1",
		"@tenkeylabs/dappwright": "^2.9.1",
		"@types/node": "^22.13.10",
		"buffer": "^6.0.3",
		"dotenv": "^16.4.7",
