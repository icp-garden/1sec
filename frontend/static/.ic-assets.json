[
	{
		"match": "**/*",
		"headers": {
			"X-Security-Policy": "hardened"
		},
		"ignore": false
	},
	{
		"match": ".well-known/ii-alternative-origins",
		"headers": {
			"Access-Control-Allow-Origin": "*",
			"Content-Type": "application/json",
			"X-Security-Policy": "hardened"
		},
		"ignore": false
	},
	{
		"match": "**/*.ttf",
		"cache": {
			"max_age": 604800
		},
		"ignore": false
	},
	{
		"match": "**/*.png",
		"cache": {
			"max_age": 604800
		},
		"ignore": false
	},
	{
		"match": "**/*.svg",
		"cache": {
			"max_age": 604800
		},
		"ignore": false
	},
	{
		"match": "**/*.webp",
		"cache": {
			"max_age": 604800
		},
		"ignore": false
	},
	{
		"match": "**/*.jpg",
		"cache": {
			"max_age": 604800
		},
		"ignore": false
	},
	{
		"match": "**/*.jpeg",
		"cache": {
			"max_age": 604800
		},
		"ignore": false
	}
]
